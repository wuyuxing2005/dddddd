  <property name="styleSheet">
   <string notr="true">/* =========================================
   1. 浩瀚底色：沉浸式钛钢灰背景 (对齐中转站)
   ========================================= */
QMainWindow, QWidget#QtWidgetsApplicationClass {
    background-color: #2B3140; /* NordSlate 底色 */
}

/* =========================================
   2. 卡片 (GroupBox) - 学术克制与绝对加粗紧凑
   ========================================= */
QGroupBox {
    background-color: #363E53; 
    border: 1px solid #454E65; 
    border-radius: 12px;
    margin-top: 25px; 
    font-family: &quot;Segoe UI Variable&quot;, &quot;Segoe UI&quot;, &quot;Microsoft YaHei&quot;, sans-serif;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center; 
    padding: 0px 12px;               
    background-color: transparent; 
    color: #FFFFFF;
    font: bold 13pt &quot;Segoe UI Variable&quot;, &quot;Segoe UI&quot;, &quot;Microsoft YaHei&quot;, sans-serif;
    letter-spacing: 1px; 
}

/* =========================================
   3. 全局字体层级与基础排版
   ========================================= */
QLabel, QCheckBox, QRadioButton {
    background-color: transparent; 
    color: #E2E8F0;
    font-family: &quot;Segoe UI Variable&quot;, &quot;Segoe UI&quot;, &quot;Microsoft YaHei&quot;, sans-serif;
    font-weight: 500;
    font-size: 11pt; 
}

/* =========================================
   4. 深邃输入/日志框 (统一为图表最深底色 #1B212D) 
   ========================================= */
QLineEdit, QPlainTextEdit {
    background-color: #1B212D; 
    color: #E2E8F0;
    border: 1px solid #454E65;
    border-radius: 6px;
    font-family: &quot;Consolas&quot;, monospace;
    padding: 6px 10px;
    outline: none; 
}
QPlainTextEdit QWidget { background-color: #1B212D; }
QLineEdit { font-size: 11pt; }
QPlainTextEdit { font-size: 9pt; }

/* 默认 Focus 防错 */
QLineEdit:focus, QPlainTextEdit:focus { 
    border: 1px solid #00D2FF; 
    background-color: #161A23;
}

/* =========================================
   ★ 5. 核心魔法：精准名称绑定的色彩继承体系 ★
   ========================================= */

/* --- 模块 A：3D Touch 家族 (科技蓝 #00D2FF) --- */
QGroupBox#groupBox_TouchConfiguration, 
QGroupBox#groupBox_Touch3D, 
QGroupBox#groupBox_TouchLog { 
    border-top: 3px solid #00D2FF; 
}
QGroupBox#groupBox_TouchConfiguration QLineEdit, 
QGroupBox#groupBox_Touch3D QLineEdit, 
QGroupBox#groupBox_TouchLog QPlainTextEdit { 
    color: #00D2FF; 
}
QGroupBox#groupBox_TouchConfiguration QLineEdit:focus, 
QGroupBox#groupBox_Touch3D QLineEdit:focus, 
QGroupBox#groupBox_TouchLog QPlainTextEdit:focus { 
    border: 1px solid #00D2FF; 
    background-color: #161A23; 
}
QGroupBox#groupBox_TouchConfiguration QRadioButton::indicator:checked {
    background-color: qradialgradient(cx:0.5, cy:0.5, radius:0.5, fx:0.5, fy:0.5, stop:0 #00D2FF, stop:0.5 #00D2FF, stop:0.55 transparent, stop:1 transparent);
}

/* --- 模块 B：Dobot 控制 (警示黄 #FFD166) --- */
QGroupBox#groupBox_ControlConfiguration { 
    border-top: 3px solid #FFD166; 
}
QGroupBox#groupBox_ControlConfiguration QLineEdit { 
    color: #FFD166; 
}
QGroupBox#groupBox_ControlConfiguration QLineEdit:focus { 
    border: 1px solid #FFD166; 
    background-color: #161A23; 
}
QGroupBox#groupBox_ControlConfiguration QRadioButton::indicator:checked {
    background-color: qradialgradient(cx:0.5, cy:0.5, radius:0.5, fx:0.5, fy:0.5, stop:0 #FFD166, stop:0.5 #FFD166, stop:0.55 transparent, stop:1 transparent);
}

/* --- 模块 C：机械爪 Claw (猛男粉 #F15BB5) --- */
QGroupBox#groupBox_Claw { border-top: 3px solid #F15BB5; }
QGroupBox#groupBox_Claw QLineEdit { color: #F15BB5; }
QGroupBox#groupBox_Claw QLineEdit:focus { 
    border: 1px solid #F15BB5; background-color: #161A23; 
}

/* --- 模块 D：压力传感器 Pressure (丁香紫 #9D4EDD) --- */
QGroupBox#groupBox_Pressure { border-top: 3px solid #9D4EDD; }
QGroupBox#groupBox_Pressure QLineEdit { color: #9D4EDD; }
QGroupBox#groupBox_Pressure QLineEdit:focus { 
    border: 1px solid #9D4EDD; background-color: #161A23; 
}

/* --- 模块 E：视觉监控 Camera (薄荷绿 #00FFCC) --- */
QGroupBox#groupBox_Camera { border-top: 3px solid #00FFCC; }
QGroupBox#groupBox_Camera QLineEdit { color: #00FFCC; }
QGroupBox#groupBox_Camera QLineEdit:focus { 
    border: 1px solid #00FFCC; background-color: #161A23; 
}
/* 专属摄像头黑屏监视器 */
QLabel#label_camera_feed {
    background-color: #1B212D; border: 1px solid #454E65; border-radius: 6px;
    color: #00FFCC; font-family: &quot;Consolas&quot;; font-size: 16pt; font-weight: bold; letter-spacing: 4px;
}

/* --- 🚀 模块 F：系统日志 System Log (单独拎出来的科技蓝 #00D2FF) --- */
QGroupBox#groupBox_SystemLog { border-top: 3px solid #00D2FF; }
QGroupBox#groupBox_SystemLog QPlainTextEdit { color: #00D2FF; }
QGroupBox#groupBox_SystemLog QPlainTextEdit:focus { 
    border: 1px solid #00D2FF; background-color: #161A23; 
}

/* =========================================
   6. 单选框指示器 (完美正圆修复)
   ========================================= */
QRadioButton::indicator {
    width: 14px; height: 14px;
    border-radius: 9px; 
    border: 2px solid #FFFFFF; 
    background-color: transparent;
}
QRadioButton::indicator:hover { background-color: rgba(255, 255, 255, 0.1); }
QRadioButton::indicator:checked { border: 2px solid #FFFFFF; } 

/* =========================================
   7. 按钮：还原红蓝色彩 &amp; 学术放大
   ========================================= */
QPushButton {
    background-color: #47526A; color: #FFFFFF;
    border: 1px solid #5A6782; border-top: 1px solid #6B7996; 
    border-radius: 6px; padding: 8px 24px; font-weight: bold; font-size: 11pt; 
}
QPushButton:hover { background-color: #55627D; }
QPushButton:pressed { background-color: #3A4459; color: #A0A0A0; }

QPushButton#pushButton_start, QPushButton#pushButton_camera_start { background-color: #0078D4; border: none; font-size: 13pt; }
QPushButton#pushButton_start:hover, QPushButton#pushButton_camera_start:hover { background-color: #2B88D8; }

QPushButton#pushButton_start_2, QPushButton#pushButton_camera_stop { background-color: #C42B1C; border: none; font-size: 13pt; }
QPushButton#pushButton_start_2:hover, QPushButton#pushButton_camera_stop:hover { background-color: #D13438; }

/* =========================================
   8. 隐形科技感滚动条 
   ========================================= */
QScrollBar:vertical {
    background: #1B212D; width: 10px; margin: 0px; border-radius: 5px;
}
QScrollBar::handle:vertical { background: #454E65; min-height: 20px; border-radius: 5px; }
QScrollBar::handle:vertical:hover { background: #5A6782; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0px; }
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical { background: none; }

/* =========================================
   9. Touch 端专属：指示灯与滑块适配
   ========================================= */
QLabel#led_touch_status, QLabel#led_dobot, QLabel#led_zhuazi, QLabel#led_pressure, QLabel#led_camera {
    width: 14px; height: 14px;
    border-radius: 9px; 
    border: 2px solid #454E65; 
    background-color: transparent;
    min-width: 14px; max-width: 14px; min-height: 14px; max-height: 14px;
}

QSlider::groove:horizontal {
    border: 1px solid #454E65; height: 6px; background: #1B212D; border-radius: 3px;
}
QSlider::sub-page:horizontal { background: #00FFCC; border-radius: 3px; }
QSlider::handle:horizontal {
    background: #FFFFFF; border: 2px solid #00FFCC;
    width: 14px; margin-top: -5px; margin-bottom: -5px; border-radius: 7px;
}
QSlider::handle:horizontal:hover { background: #E2E8F0; }</string>
