   <property name="styleSheet">
    <string notr="true">/* =========================================
   1. 浩瀚底色：沉浸式钛钢灰背景 ( SCI Paper Printable )
   ========================================= */
QMainWindow, QWidget#centralWidget {
    background-color: #2B3140; /* NordSlate 底色 */
}

/* =========================================
   2. 卡片 (GroupBox) - 学术克制与霓虹切边
   ========================================= */
QGroupBox {
    background-color: #363E53; 
    border: 1px solid #454E65; 
    border-radius: 12px;
    margin-top: 32px; 
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center; 
    padding: 6px 16px;
    background-color: transparent; 
    color: #FFFFFF;
    font-weight: bold;
    font-size: 11pt; 
    min-height: 20px;
}

/* 霓虹切边 */
QGroupBox#box_config { border-top: 3px solid #00D2FF; } 
QGroupBox#box_interact { border-top: 3px solid #00FFCC; } 
QGroupBox#box_state { border-top: 3px solid #FFD166; } 
QGroupBox#box_latency { border-top: 3px solid #9D4EDD; } 
QGroupBox#group_network_latency { border-top: 3px solid #F15BB5; } 

/* =========================================
   3. 全局字体层级与基础排版
   ========================================= */
QLabel, QCheckBox, QRadioButton {
    background-color: transparent; 
    color: #E2E8F0;
    font-family: &quot;Segoe UI Variable&quot;, &quot;Segoe UI&quot;, &quot;Microsoft YaHei&quot;, sans-serif;
    font-weight: 500;
    font-size: 11pt; 
}

/* =========================================
   ★ 核心修复：深邃输入/日志框 (对齐图表 #1B212D) ★
   ========================================= */
QLineEdit, QPlainTextEdit, QListWidget {
    background-color: #1B212D; /* 统一为图表最深底色 */
    color: #E2E8F0;
    border: 1px solid #454E65;
    border-radius: 6px;
    font-family: &quot;Consolas&quot;, monospace;
    padding: 6px 10px;
    outline: none; /* 去除虚线框 */
}

/* 强制覆盖文本框内部视口，防止底色溢出泛白 */
QPlainTextEdit QWidget, QListWidget QWidget {
    background-color: #1B212D;
}

QLineEdit, QListWidget { font-size: 11pt; }
QPlainTextEdit { font-size: 9pt; }

/* =========================================
   ★ 模块专属颜色与点击深陷特效 (Focus) ★
   ========================================= */

/* 1. 参数配置区 (科技蓝) */
QGroupBox#box_config QLineEdit { color: #00D2FF; }
QGroupBox#box_config QLineEdit:focus { 
    border: 1px solid #00D2FF; 
    background-color: #161A23; /* 点击后背景更深，产生深陷质感 */
}

/* 2. 信息交互区 (薄荷绿) */
QGroupBox#box_interact QPlainTextEdit, 
QGroupBox#box_interact QListWidget { color: #00FFCC; }
QGroupBox#box_interact QPlainTextEdit:focus, 
QGroupBox#box_interact QListWidget:focus { 
    border: 1px solid #00FFCC; 
    background-color: #161A23; 
}

/* 3. 通信状态区 (警示黄) */
QGroupBox#box_state QPlainTextEdit, 
QGroupBox#box_state QListWidget { color: #FFD166; }
QGroupBox#box_state QPlainTextEdit:focus, 
QGroupBox#box_state QListWidget:focus { 
    border: 1px solid #FFD166; 
    background-color: #161A23; 
}

/* 4. 其他默认防错 */
QLineEdit:focus, QPlainTextEdit:focus, QListWidget:focus { 
    border: 1px solid #00D2FF; 
}

/* =========================================
   4. 平均时延专属数值框
   ========================================= */
QLineEdit#avg_relay_latency {
    color: #9D4EDD; 
    font-weight: bold;
    font-size: 12pt;
    background-color: #1B212D;
}
QLineEdit#avg_relay_latency:focus {
    border: 1px solid #9D4EDD; 
    background-color: #161A23;
}

QLineEdit#avg_network_latency {
    color: #F15BB5; 
    font-weight: bold;
    font-size: 12pt;
    background-color: #1B212D;
}
QLineEdit#avg_network_latency:focus {
    border: 1px solid #F15BB5; 
    background-color: #161A23;
}

/* =========================================
   5. 隐形科技感滚动条 (ScrollBar)
   ========================================= */
QScrollBar:vertical {
    background: #1B212D; /* 轨道颜色与文本框一致 */
    width: 10px;
    margin: 0px;
    border-radius: 5px;
}
QScrollBar::handle:vertical {
    background: #454E65; /* 滑块颜色 */
    min-height: 20px;
    border-radius: 5px;
}
QScrollBar::handle:vertical:hover {
    background: #5A6782; /* 悬停时稍微点亮 */
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px; /* 隐藏上下箭头，更极简 */
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

/* =========================================
   6. 单选框指示器
   ========================================= */
/* --- 单选框 (Radio Button) 终极正圆修复 --- */
QRadioButton::indicator {
    width: 14px;
    height: 14px;
    border-radius: 9px; /* 魔法数字：(14宽高 + 4边框) / 2 = 9，强制绝对正圆 */
    border: 2px solid #FFFFFF; /* 保持纯白边框 */
    background-color: transparent;
    /* 注意：删除了 padding，防止盒子被撑成半方半圆 */
}

QRadioButton::indicator:hover {
    background-color: rgba(255, 255, 255, 0.1); /* 悬停微光 */
}

/* 选中状态：保持纯白外边框，用【径向渐变】在中心画出缩小的圆点 */
QRadioButton::indicator:checked {
    border: 2px solid #FFFFFF;
    /* 默认科技蓝内圆：从中心到 50% 半径是蓝色，之后透明 */
    background-color: qradialgradient(cx:0.5, cy:0.5, radius:0.5, fx:0.5, fy:0.5, stop:0 #00D2FF, stop:0.5 #00D2FF, stop:0.55 transparent, stop:1 transparent);
}

/* 专属面板颜色：处理时延 (丁香紫内圆) */
QGroupBox#box_latency QRadioButton::indicator:checked {
    border: 2px solid #FFFFFF; /* 强制白边框不变 */
    /* 丁香紫内圆：完美呼应你的紫色坐标轴和平均值 */
    background-color: qradialgradient(cx:0.5, cy:0.5, radius:0.5, fx:0.5, fy:0.5, stop:0 #9D4EDD, stop:0.5 #9D4EDD, stop:0.55 transparent, stop:1 transparent);
}

/* 如果网络面板也有单选框：保留猛男粉内圆 */
QGroupBox#group_network_latency QRadioButton::indicator:checked {
    border: 2px solid #FFFFFF;
    background-color: qradialgradient(cx:0.5, cy:0.5, radius:0.5, fx:0.5, fy:0.5, stop:0 #F15BB5, stop:0.5 #F15BB5, stop:0.55 transparent, stop:1 transparent);
}

/* =========================================
   7. 按钮：还原红蓝色彩 &amp; 学术放大
   ========================================= */
QPushButton {
    background-color: #47526A;
    color: #FFFFFF;
    border: 1px solid #5A6782;
    border-top: 1px solid #6B7996; 
    border-radius: 6px;
    padding: 8px 24px;
    font-weight: bold;
    font-size: 11pt; 
}
QPushButton:hover { background-color: #55627D; }
QPushButton:pressed { background-color: #3A4459; color: #A0A0A0; }

QPushButton#btn_start, QPushButton#btn_stop { font-size: 13pt; }
QPushButton#btn_start { background-color: #0078D4; border: none;}
QPushButton#btn_start:hover { background-color: #2B88D8; }
QPushButton#btn_stop { background-color: #C42B1C; border: none;}
QPushButton#btn_stop:hover { background-color: #D13438; }

/* =========================================
   8. Disabled (禁用/未激活) 状态样式
   ========================================= */
QGroupBox::title:disabled, 
QLabel:disabled, 
QCheckBox:disabled, 
QRadioButton:disabled { color: #5C677D; }

QRadioButton::indicator:disabled, 
QCheckBox::indicator:disabled {
    border: 2px solid #454E65; 
    background-color: transparent;
}

QLineEdit:disabled, QPlainTextEdit:disabled {
    background-color: #2B3140; 
    border: 1px solid #3B4252;
    color: #5C677D; 
}

QPushButton:disabled {
    background-color: #363E53;
    border: 1px solid #3B4252;
    color: #5C677D;
}

/* =========================================
   ★ 终极破局：QGroupBox 标题指示器 -&gt; 完美正圆 ★
   ========================================= */

/* 1. 未选中状态：强行变成完美正圆白框 */
QGroupBox#group_network_latency::indicator {
    width: 14px;  /* 尺寸与下方的 RadioButton 完全统一 */
    height: 14px;
    border: 2px solid #FFFFFF; 
    border-radius: 9px; /* 魔法数学：(14 + 2*2) / 2 = 9px，绝对的完美正圆！ */
    background-color: transparent;
    margin-top: 2px;
}

/* 2. 悬停状态：轻微泛白反光 */
QGroupBox#group_network_latency::indicator:hover {
    background-color: rgba(255, 255, 255, 0.1);
}

/* 3. 选中状态：白边框 + 【猛男粉内圆】 */
QGroupBox#group_network_latency::indicator:checked {
    border: 2px solid #FFFFFF; 
    background-color: qradialgradient(cx:0.5, cy:0.5, radius:0.5, fx:0.5, fy:0.5, stop:0 #F15BB5, stop:0.5 #F15BB5, stop:0.55 transparent, stop:1 transparent);
}</string>
